{% extends 'base.html.twig' %}

{% block title %}Akwarium - Strona główna{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section content-center mb-12" id="hero">
        <div class="container">
            <div class="flex flex-wrap items-center text-center lg:text-left">
                <div class="w-full lg:w-1/2 hero-content p-2 lg:p-0">
                    <h1 class="mb-6">Twoje ładunki – nasza odpowiedzialność. Globalna logistyka na najwyższym poziomie.</h1>
                    <p class="mb-6">
                        Firma spedycyjno-transportowa – niezawodny partner logistyczny, który dostarczy Twój towar szybko i bezpiecznie w dowolne miejsce na świecie. Działamy 24/7, oferując ekspresowy transport lądowy, w tym przewóz materiałów ADR. Skontaktuj się z nami już dziś i poznaj naszą ofertę!
                    </p>
                    <div class="flex items-center mb-6 flex-col lg:flex-row text-center lg:text-left">
                        <a href="#contact" class="btn btn-primary mb-4 lg:mb-0">Skontaktuj się z nami</a>
                        <div class="flex items-center lg:ml-4 justify-center">
                            <img src="{{ asset('images/phone_inverse.png') }}" alt="Phone Icon" class="max-w-full h-auto w-[53px]">
                            <a class="text-white no-underline ml-4" href="tel:+48604324770">+48 604 324 770</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Feature Section -->
    <section class="py-12" id="feature">
        <div class="container">
            <div class="flex flex-wrap items-center">
                <div class="w-full lg:w-5/12 mb-12 lg:mb-0">
                    <h2 class="mb-6 font-bold">
                        Bezpieczny i szybki <span class="text-brand-red">transport</span>
                        <br>na każdym etapie drogi.
                    </h2>

                    <div class="mb-6">
                        <div class="flex items-center">
                            <div class="mx-auto shrink-0">
                                <svg width="34" height="52" viewBox="0 0 34 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2 37H0V39H2V37ZM33.4142 38.4142C34.1953 37.6332 34.1953 36.3668 33.4142 35.5858L20.6863 22.8579C19.9052 22.0768 18.6389 22.0768 17.8579 22.8579C17.0768 23.6389 17.0768 24.9052 17.8579 25.6863L29.1716 37L17.8579 48.3137C17.0768 49.0948 17.0768 50.3611 17.8579 51.1421C18.6389 51.9232 19.9052 51.9232 20.6863 51.1421L33.4142 38.4142ZM0 0V37H4V0H0ZM2 39H32V35H2V39Z" fill="#DE2C2C"/>
                                </svg>
                            </div>
                            <p class="ml-6 mb-0">
                                Jako międzynarodowy lider w branży spedycyjnej, oferuje kompleksowe usługi logistyczne, które spełniają najbardziej wymagające potrzeby naszych klientów.
                            </p>
                        </div>
                    </div>

                    <div class="mb-6">
                        <div class="flex items-center">
                            <div class="shrink-0">
                                <svg width="34" height="52" viewBox="0 0 34 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2 37H0V39H2V37ZM33.4142 38.4142C34.1953 37.6332 34.1953 36.3668 33.4142 35.5858L20.6863 22.8579C19.9052 22.0768 18.6389 22.0768 17.8579 22.8579C17.0768 23.6389 17.0768 24.9052 17.8579 25.6863L29.1716 37L17.8579 48.3137C17.0768 49.0948 17.0768 50.3611 17.8579 51.1421C18.6389 51.9232 19.9052 51.9232 20.6863 51.1421L33.4142 38.4142ZM0 0V37H4V0H0ZM2 39H32V35H2V39Z" fill="#232427"/>
                                </svg>
                            </div>
                            <p class="ml-6 mb-0">
                                Nasza flota samochodów, ciężarówek i busów gotowa jest na przewozy ekspresowe, a nasze usługi dostępne są 24 godziny na dobę, 7 dni w tygodniu.
                            </p>
                        </div>
                    </div>

                    <div class="mb-6">
                        <div class="flex items-center">
                            <div class="shrink-0">
                                <svg width="34" height="52" viewBox="0 0 34 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M2 37H0V39H2V37ZM33.4142 38.4142C34.1953 37.6332 34.1953 36.3668 33.4142 35.5858L20.6863 22.8579C19.9052 22.0768 18.6389 22.0768 17.8579 22.8579C17.0768 23.6389 17.0768 24.9052 17.8579 25.6863L29.1716 37L17.8579 48.3137C17.0768 49.0948 17.0768 50.3611 17.8579 51.1421C18.6389 51.9232 19.9052 51.9232 20.6863 51.1421L33.4142 38.4142ZM0 0V37H4V0H0ZM2 39H32V35H2V39Z" fill="#DE2C2C"/>
                                </svg>
                            </div>
                            <p class="ml-6 mb-0">
                                Specjalizujemy się także w przewozach materiałów niebezpiecznych (ADR), dbając o pełne bezpieczeństwo i zgodność z przepisami.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="w-full lg:w-6/12 lg:ml-[8.333%]">
                    <div class="flex flex-wrap relative">
                        <div class="w-[55%] ml-[20%] z-[3]">
                            <img src="{{ asset('images/feature-1.png') }}" alt="" class="max-w-full h-auto rounded-3xl shadow">
                        </div>
                        <div class="w-[55%] -mt-[40%] ml-[45%] z-[4]">
                            <img src="{{ asset('images/feature-2.png') }}" alt="" class="max-w-full h-auto">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Vehicles Offer Section -->
    <section class="py-12" id="offer">
        <div class="w-full">
            <div class="bg-brand-info text-white text-center mb-12 content-center py-12">
                <h2 class="font-bold">Oferta pojazdów</h2>
            </div>
        </div>

        <div class="container">
            <div class="flex flex-wrap justify-center">
                <div class="w-full xl:w-10/12 text-center">

                <!-- Busy -->
                <div class="text-center my-6">
                    <h3 class="bg-brand-dark text-white inline-block px-6 py-2 mb-6">Busy</h3>
                    <h4 class="mb-4">Szybki transport na krótkich dystansach</h4>
                    <p class="text-gray-500">
                        Nasze busy idealnie sprawdzają się w ekspresowych dostawach mniejszych ładunków.
                        <br>Zapewniają szybkość, elastyczność i dostępność, nawet w trudno dostępnych lokalizacjach
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4 lg:flex lg:flex-wrap lg:justify-center lg:gap-4 mb-12">
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info px-4 py-6 text-center rounded-lg vehicle-img-container">
                                <img src="{{ asset('images/oferta/bus.png') }}" alt="Bus" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Bus</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info px-4 py-6 text-center rounded-lg vehicle-img-container">
                                <img src="{{ asset('images/oferta/bus-plandeka.png') }}" alt="Bus" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Bus<br>+ plandeka</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ciężarówki solowe -->
                <div class="text-center my-6">
                    <h3 class="bg-brand-dark text-white inline-block px-6 py-2 mb-6">Ciężarówki solowe</h3>
                    <h4 class="mb-4">Niezawodność i wszechstronność</h4>
                    <p class="text-gray-500">
                        Ciężarówki solowe to idealne rozwiązanie dla krajowych przewozów kontraktowych na średnich
                        i dłuższych trasach. Duża ich dostępność, niezawodność, szeroki zakres ładowności i możliwość
                        szybkiego dopasowania możliwości pojazdu do wymagań.
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4 lg:flex lg:flex-wrap lg:justify-center lg:gap-4 mb-12">
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container">
                                <img src="{{ asset('images/oferta/solowka.png') }}" alt="Solówka" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Solówka</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container">
                                <img src="{{ asset('images/oferta/solowka-plandeka.png') }}" alt="Solówka + plandeka" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Solówka<br>+ plandeka</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tandem -->
                <div class="text-center my-6">
                    <h3 class="bg-brand-dark text-white inline-block px-6 py-2 mb-6">Tandem</h3>
                    <h4 class="mb-4">Maksymalna pojemność na każdą trasę</h4>
                    <p class="text-gray-500">
                        Zestawy tandemowe umożliwiają przewóz dużych ładunków, łącząc pojemność z doskonałą manewrowością. Idealne do transportu wielkogabarytowego, gwarantują efektywność na długich dystansach.
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4 lg:flex lg:flex-wrap lg:justify-center lg:gap-4 mb-12">
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/auto-przyczepa.png') }}" alt="Auto + przyczepa" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Auto + przyczepa</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Ciągniki siodłowe i naczepy -->
                <div class="text-center my-6">
                    <h3 class="bg-brand-dark text-white inline-block px-6 py-2 mb-6">Ciągniki siodłowe i naczepy</h3>
                    <h4 class="mb-4">Moc i wydajność dla wymagających ładunków</h4>
                    <p class="text-gray-500">
                        Nasze ciągniki siodłowe, wyposażone w nowoczesne naczepy, doskonale sprawdzają się w przewozie ciężkich i dużych ładunków na dalekich trasach. Zapewniają stabilność, bezpieczeństwo i niezawodność, nawet przy najbardziej wymagających zleceniach.
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-4 lg:flex lg:flex-wrap lg:justify-center lg:gap-4 mb-12">
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/naczepa-standard.png') }}" alt="Naczepa standard" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Naczepa standard</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/naczepa-mega.png') }}" alt="Naczepa MEGA" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Naczepa MEGA</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/wywrotka.png') }}" alt="Wywrotka" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Wywrotka</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/chlodnia.png') }}" alt="Chłodnia" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Chłodnia</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/chlodnia.png') }}" alt="Izoterma" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Izoterma</h3>
                            </div>
                        </div>
                    </div>
                    <div class="lg:w-auto">
                        <div class="h-full bg-gray-50 rounded-lg overflow-hidden">
                            <div class="bg-brand-info p-4 text-center rounded-lg vehicle-img-container-large">
                                <img src="{{ asset('images/oferta/cysterna.png') }}" alt="Cysterna" class="max-w-full h-auto">
                            </div>
                            <div class="text-center content-center p-4">
                                <h3 class="font-bold">Cysterna</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center my-6">
                    <h3 class="bg-brand-dark text-white inline-block px-6 py-2 mb-6">Do dyspozycji również auta wyposażone w windy wraz z paleciakiem.</h3>
                </div>

            </div></div>
        </div>
    </section>

    <!-- Dlaczego my? Section -->
    <section class="py-12 bg-[#212529]" id="why-us">
        <div class="container">
            <div class="flex items-center mb-12">
                <h2 class="text-white font-bold mb-0 mr-4 shrink-0">Dlaczego my?</h2>
                <div class="grow">
                    <hr class="border-white opacity-100" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 xl:gap-6">
                <!-- Globalny zasięg -->
                <div class="bg-white h-full rounded p-4 xl:p-12">
                    <div class="text-center content-center mb-6 min-h-[100px]">
                        <svg width="60" height="86" viewBox="0 0 60 86" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M10.4989 40.0936C12.8416 44.478 16.0537 49.2007 19.2747 53.5004L19.2751 53.5009C23.8334 59.5768 26.8431 62.8684 28.8059 65.015C29.0297 65.2597 29.2398 65.4896 29.4371 65.707L29.9914 66.3178L30.5469 65.7081C30.7369 65.4995 30.9387 65.2796 31.153 65.046C33.1222 62.8996 36.1444 59.6054 40.7177 53.5004C43.9394 49.1998 47.1437 44.4774 49.4935 40.0938L49.4937 40.0934C50.6687 37.8981 51.603 35.7665 52.2453 33.8788C52.883 32.0046 53.25 30.3213 53.25 29.0381C53.25 16.7062 42.919 6.72826 30 6.72826C17.0734 6.72826 6.75001 16.7064 6.75001 29.0381C6.75001 30.3202 7.1127 32.0028 7.74776 33.8778C8.38724 35.7658 9.31976 37.8977 10.4989 40.0936ZM10.4989 40.0936C10.4987 40.0934 10.4986 40.0931 10.4985 40.0929L11.16 39.7395M10.4989 40.0936C10.499 40.0938 10.4991 40.0941 10.4992 40.0943L11.16 39.7395M11.16 39.7395C8.83499 35.4096 7.50001 31.3638 7.50001 29.0381C7.50001 17.1477 17.46 7.47826 30 7.47826C42.5325 7.47826 52.5 17.1477 52.5 29.0381C52.5 31.3638 51.15 35.4096 48.8325 39.7395C46.5075 44.0769 43.3275 48.7657 40.1175 53.0508C35.5664 59.126 32.564 62.3986 30.5991 64.5403C30.5661 64.5763 30.5334 64.6119 30.501 64.6473C30.5167 64.6646 30.5323 64.6818 30.5479 64.6989L29.9925 65.203L29.4381 64.6978C29.4537 64.6808 29.4693 64.6636 29.485 64.6464C29.444 64.6015 29.4026 64.5561 29.3606 64.5103C27.4018 62.368 24.4116 59.0977 19.875 53.0508C16.665 48.7657 13.4775 44.0769 11.16 39.7395ZM42.8259 60.3836L43.3795 60.686C47.2315 62.79 49.5 65.627 49.5 68.3962C49.5 70.9589 47.7968 73.5249 44.3363 75.6527C44.336 75.6529 44.3357 75.6531 44.3353 75.6533L43.9425 75.0144C40.5975 77.0784 35.5875 78.5217 29.9925 78.5217C24.4125 78.5217 19.4175 77.0784 16.065 75.0144L42.8259 60.3836ZM42.8259 60.3836L42.4331 60.8772C39.7327 64.2708 37.1663 67.3279 35.2747 69.5367C34.3291 70.641 33.5524 71.5328 33.0125 72.1483C32.7426 72.456 32.5318 72.6946 32.3887 72.8561C32.3172 72.9368 32.2626 72.9983 32.2259 73.0394L32.1845 73.0859L32.1772 73.094C31.8979 73.3898 31.5609 73.6258 3