{% extends 'base.html.twig' %}

{% block title %}Akwarium - Logistyka{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section content-center mb-12" id="hero" style="background-image: url('{{ asset("images/header-4.jpg") }}') !important;">
        <div class="container">
            <div class="flex flex-wrap items-center text-center lg:text-left">
                <div class="w-full lg:w-1/2 hero-content p-2 lg:p-0">
                    <h1 class="mb-6">Kompleksowe zarządzanie łańcuchem dostaw</h1>
                    <p class="mb-6">
                        Logistyka to coś więcej niż tylko transport – to sztuka zarządzania całym łańcuchem dostaw. Oferujemy pełne wsparcie logistyczne, od planowania, przez koordynację, po realizację dostaw na każdym etapie. Dzięki naszym nowoczesnym rozwiązaniom i zaawansowanym technologiom zapewniamy sprawny przepływ towarów, minimalizując przestoje i maksymalizując efektywność.
                    </p>
                    <div class="flex items-center mb-6 flex-col lg:flex-row text-center lg:text-left">
                        <a href="{{ path('home') }}#contact" class="btn btn-secondary mb-4 lg:mb-0">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services Section -->
    <section class="py-12">
        <div class="container">
            <div class="flex flex-wrap items-center mb-12">
                <div class="w-full lg:w-5/12 mb-6 lg:mb-0 px-12 lg:px-0 order-2 lg:order-first">
                    <img src="{{ asset('images/feature-5.png') }}" alt="" class="max-w-full h-auto">
                </div>
                <div class="w-full lg:w-7/12 lg:px-12 order-first lg:order-last">
                    <h2 class="font-bold mb-12">Usługi logistyczne</h2>
                    <div>
                        <div class="flex mb-12">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Planowanie tras i optymalizacja dostaw – Zawsze najkrótsza i najbezpieczniejsza droga do celu.</p>
                            </div>
                        </div>
                        <div class="flex mb-12">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Magazynowanie i zarządzanie zapasami – Nowoczesne centra logistyczne, które pozwalają na bezpieczne przechowywanie towarów.</p>
                            </div>
                        </div>
                        <div class="flex mb-12 lg:mb-0">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Monitorowanie 24/7 – Stały nadzór nad Twoim ładunkiem, dzięki systemom GPS i nowoczesnym rozwiązaniom IT.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0 lg:pt-12 pb-12">
        <div class="container">
            <div class="w-full mx-auto">
                <div class="bg-gray-50 border-0 shadow-sm rounded-3xl py-6 px-6">
                    <div class="text-center p-6">
                        <h4 class="mb-6 md:px-12">
                            Zaufaj nam, aby Twoje procesy logistyczne były bardziej efektywne, bezpieczne i oszczędne. Dzięki współpracy z nami zyskasz czas, pewność oraz pełną kontrolę nad transportem towarów.
                        </h4>
                        <a href="{{ path('home') }}#contact" class="btn btn-primary">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
