{% extends 'base.html.twig' %}

{% block title %}Akwarium - Logistyka{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section align-content-center mb-5" id="hero" style="background-image: url('{{ asset("images/header-4.jpg") }}') !important;">
        <div class="container">
            <div class="row align-items-center text-center text-lg-start">
                <div class="col-12 col-lg-6 hero-content p-2 p-lg-0">
                    <h1 class="mb-4">Kompleksowe zarządzanie łańcuchem dostaw</h1>
                    <p class="mb-4">
                        Logistyka to coś więcej niż tylko transport – to sztuka zarządzania całym łańcuchem dostaw. Oferujemy pełne wsparcie logistyczne, od planowania, przez koordynację, po realizację dostaw na każdym etapie. Dzięki naszym nowoczesnym rozwiązaniom i zaawansowanym technologiom zapewniamy sprawny przepływ towarów, minimalizując przestoje i maksymalizując efektywność.
                    </p>
                    <div class="d-flex align-items-center mb-4 flex-lg-row flex-column text-center text-lg-start">
                        <a href="{{ path('home') }}#contact" class="btn btn-secondary mb-3 mb-lg-0">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services Section -->
    <section class="services-section py-5">
        <div class="container">
            <div class="row align-items-center mb-5">
                <div class="col-lg-5 mb-4 mb-lg-0 px-5 px-lg-0 order-2 order-lg-first">
                    <img src="{{ asset('images/feature-5.png') }}" alt="" class="img-fluid">
                </div>
                <div class="col-lg-7 px-lg-5 order-first order-lg-last">
                    <h2 class="fw-bold mb-5">Usługi logistyczne</h2>
                    <div class="service-list">
                        <div class="d-flex mb-5">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Planowanie tras i optymalizacja dostaw – Zawsze najkrótsza i najbezpieczniejsza droga do celu.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Magazynowanie i zarządzanie zapasami – Nowoczesne centra logistyczne, które pozwalają na bezpieczne przechowywanie towarów.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5 mb-lg-0">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Monitorowanie 24/7 – Stały nadzór nad Twoim ładunkiem, dzięki systemom GPS i nowoczesnym rozwiązaniom IT.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section pt-0 pt-lg-5 pb-5">
        <div class="container">
            <div class="row">
                <div class="col-12 mx-auto">
                    <div class="card border-0 shadow-sm rounded-5 py-4 px-4 bg-light">
                        <div class="card-body text-center">
                            <h4 class="mb-4 px-md-5">
                                Zaufaj nam, aby Twoje procesy logistyczne były bardziej efektywne, bezpieczne i oszczędne. Dzięki współpracy z nami zyskasz czas, pewność oraz pełną kontrolę nad transportem towarów.
                            </h4>
                            <a href="{{ path('home') }}#contact" class="btn btn-primary">Skontaktuj się z nami</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
