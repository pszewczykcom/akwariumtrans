{% extends 'base.html.twig' %}

{% block title %}Akwarium - Spedycja{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section content-center mb-12" id="hero" style="background-image: url('{{ asset("images/header-2.jpg") }}') !important;">
        <div class="container">
            <div class="flex flex-wrap items-center text-center lg:text-left">
                <div class="w-full lg:w-1/2 hero-content p-2 lg:p-0">
                    <h1 class="mb-6">Szybkość i niezawodność na każdej trasie</h1>
                    <p class="mb-6">
                        Spedycja w naszej firmie to nie tylko przewóz ładunków – to kompleksowa obsługa każdego transportu od początku do końca. Dzięki naszej rozbudowanej sieci partnerów oraz bogatemu doświadczeniu w międzynarodowej spedycji, zapewniamy terminowe i bezpieczne dostarczenie towarów niezależnie od miejsca docelowego.
                    </p>
                    <div class="flex items-center mb-6 flex-col lg:flex-row text-center lg:text-left">
                        <a href="{{ path('home') }}#contact" class="btn btn-secondary mb-4 lg:mb-0">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services Section -->
    <section class="py-12">
        <div class="container">
            <div class="flex flex-wrap items-center mb-12">
                <div class="w-full lg:w-5/12 mb-6 lg:mb-0 px-12 lg:px-0 order-2 lg:order-first">
                    <img src="{{ asset('images/feature-3.png') }}" alt="" class="max-w-full h-auto">
                </div>
                <div class="w-full lg:w-7/12 lg:px-12 order-first lg:order-last">
                    <h2 class="font-bold mb-12">Usługi spedycyjne</h2>
                    <div>
                        <div class="flex mb-12">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Organizacja transportu krajowego i międzynarodowego – obserwujemy rynek i dobór transportu do specyficznych wymagań i wagi ładunków.</p>
                            </div>
                        </div>
                        <div class="flex mb-12">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Konwojowanie i ubezpieczenia – zapewniamy pełne wsparcie w obszarze ubezpieczenia ładunku i organizacji z przewoźnikami.</p>
                            </div>
                        </div>
                        <div class="flex mb-12 lg:mb-0">
                            <div class="mr-6 shrink-0" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 font-normal">Monitorowanie przesyłek w czasie rzeczywistym – stała kontrola nad przesyłką dzięki nowoczesnym technologiom śledzenia.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0 lg:pt-12 pb-12">
        <div class="container">
            <div class="w-full mx-auto">
                <div class="bg-gray-50 border-0 shadow-sm rounded-3xl py-6 px-6">
                    <div class="text-center p-6">
                        <h4 class="mb-6 md:px-12">
                            Z nami możesz mieć pewność, że Twój ładunek dotrze do celu bezpiecznie i na czas.
                            <br> Jesteśmy partnerem, któremu możesz zaufać w każdej kwestii spedycyjnej.
                        </h4>
                        <a href="{{ path('home') }}#contact" class="btn btn-primary">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
