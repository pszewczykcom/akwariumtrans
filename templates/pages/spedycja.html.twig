{% extends 'base.html.twig' %}

{% block title %}Akwarium - Spedycja{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section align-content-center mb-5" id="hero" style="background-image: url('{{ asset("images/header-2.jpg") }}') !important;">
        <div class="container">
            <div class="row align-items-center text-center text-lg-start">
                <div class="col-12 col-lg-6 hero-content p-2 p-lg-0">
                    <h1 class="mb-4">Szybkość i niezawodność na każdej trasie</h1>
                    <p class="mb-4">
                        Spedycja w naszej firmie to nie tylko przewóz ładunków – to kompleksowa obsługa każdego transportu od początku do końca. Dzięki naszej rozbudowanej sieci partnerów oraz bogatemu doświadczeniu w międzynarodowej spedycji, zapewniamy terminowe i bezpieczne dostarczenie towarów niezależnie od miejsca docelowego.
                    </p>
                    <div class="d-flex align-items-center mb-4 flex-lg-row flex-column text-center text-lg-start">
                        <a href="{{ path('home') }}#contact" class="btn btn-secondary mb-3 mb-lg-0">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services Section -->
    <section class="services-section py-5">
        <div class="container">
            <div class="row align-items-center mb-5">
                <div class="col-lg-5 mb-4 mb-lg-0 px-5 px-lg-0 order-2 order-lg-first">
                    <img src="{{ asset('images/feature-3.png') }}" alt="" class="img-fluid">
                </div>
                <div class="col-lg-7 px-lg-5 order-first order-lg-last">
                    <h2 class="fw-bold mb-5">Usługi spedycyjne</h2>
                    <div class="service-list">
                        <div class="d-flex mb-5">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Organizacja transportu krajowego i międzynarodowego – obserwujemy rynek i dobór transportu do specyficznych wymagań i wagi ładunków.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Konwojowanie i ubezpieczenia – zapewniamy pełne wsparcie w obszarze ubezpieczenia ładunku i organizacji z przewoźnikami.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5 mb-lg-0">
                            <div class="me-4" style="min-width: 6px; background-color: #dc3545;"></div>
                            <div>
                                <p class="mb-0 fw-normal">Monitorowanie przesyłek w czasie rzeczywistym – stała kontrola nad przesyłką dzięki nowoczesnym technologiom śledzenia.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="cta-section pt-0 pt-lg-5 pb-5">
        <div class="container">
            <div class="row">
                <div class="col-12 mx-auto">
                    <div class="card border-0 shadow-sm rounded-5 py-4 px-4 bg-light">
                        <div class="card-body text-center">
                            <h4 class="mb-4 px-md-5">
                                Z nami możesz mieć pewność, że Twój ładunek dotrze do celu bezpiecznie i na czas.
                                <br> Jesteśmy partnerem, któremu możesz zaufać w każdej kwestii spedycyjnej.
                            </h4>
                            <a href="{{ path('home') }}#contact" class="btn btn-primary">Skontaktuj się z nami</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
