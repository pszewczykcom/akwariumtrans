{% extends 'base.html.twig' %}

{% block title %}Akwarium - Spedycja{% endblock %}

{% block body %}
    <header class="hero-section mb-12 flex items-center" id="hero" style="background-image: url('{{ asset("images/header-2.jpg") }}') !important;">
        <div class="mx-auto w-full max-w-[1320px] px-3">
            <div class="grid items-center text-center lg:grid-cols-2 lg:text-left">
                <div class="hero-content w-full px-2 lg:px-0">
                    <h1 class="mb-4">Szybkość i niezawodność na każdej trasie</h1>
                    <p class="mb-4 max-w-[38rem] text-white/90">
                        Spedycja w naszej firmie to nie tylko przewóz ładunków – to kompleksowa obsługa każdego transportu od początku do końca. Dzięki naszej rozbudowanej sieci partnerów oraz bogatemu doświadczeniu w międzynarodowej spedycji, zapewniamy terminowe i bezpieczne dostarczenie towarów niezależnie od miejsca docelowego.
                    </p>
                    <div class="flex justify-center lg:justify-start">
                        <a href="{{ path('home') }}#contact" class="inline-flex min-h-[53px] items-center justify-center rounded-full bg-brand-blue px-5 py-[15px] text-[0.937rem] font-medium text-white no-underline shadow-brand transition duration-200 hover:bg-brand-blue-dark hover:shadow-brand-hover">
                            Skontaktuj się z nami
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="py-12">
        <div class="mx-auto w-full max-w-[1320px] px-3">
            <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,5fr)_minmax(0,7fr)]">
                <div class="order-2 px-5 lg:order-1 lg:px-0">
                    <img src="{{ asset('images/feature-3.png') }}" alt="">
                </div>
                <div class="order-1 lg:order-2 lg:px-10">
                    <h2 class="mb-8 font-bold">Usługi spedycyjne</h2>
                    <div>
                        <div class="mb-8 flex gap-4">
                            <div class="w-[6px] shrink-0 bg-brand-red"></div>
                            <p class="m-0 font-normal">Organizacja transportu krajowego i międzynarodowego – obserwujemy rynek i dobór transportu do specyficznych wymagań i wagi ładunków.</p>
                        </div>
                        <div class="mb-8 flex gap-4">
                            <div class="w-[6px] shrink-0 bg-brand-red"></div>
                            <p class="m-0 font-normal">Konwojowanie i ubezpieczenia – zapewniamy pełne wsparcie w obszarze ubezpieczenia ładunku i organizacji z przewoźnikami.</p>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-[6px] shrink-0 bg-brand-red"></div>
                            <p class="m-0 font-normal">Monitorowanie przesyłek w czasie rzeczywistym – stała kontrola nad przesyłką dzięki nowoczesnym technologiom śledzenia.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pb-12 pt-0 lg:pb-16 lg:pt-8">
        <div class="mx-auto w-full max-w-[1320px] px-3">
            <div class="rounded-[2.5rem] bg-brand-light px-4 py-8 text-center shadow-sm lg:px-6">
                <h4 class="mb-4 lg:px-16">
                    Z nami możesz mieć pewność, że Twój ładunek dotrze do celu bezpiecznie i na czas.
                    <br> Jesteśmy partnerem, któremu możesz zaufać w każdej kwestii spedycyjnej.
                </h4>
                <a href="{{ path('home') }}#contact" class="inline-flex min-h-[53px] items-center justify-center rounded-full bg-brand-red px-5 py-[15px] text-[0.937rem] font-medium text-white no-underline shadow-brand transition duration-200 hover:bg-brand-red-dark hover:shadow-brand-hover">
                    Skontaktuj się z nami
                </a>
            </div>
        </div>
    </section>
{% endblock %}
