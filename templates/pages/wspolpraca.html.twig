{% extends 'base.html.twig' %}

{% block title %}Akwarium - Współpraca{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <header class="hero-section align-content-center mb-5" id="hero" style="background-image: url('{{ asset("images/header-5.jpg") }}') !important;">
        <div class="container">
            <div class="row align-items-center text-center text-lg-start">
                <div class="col-12 col-lg-6 hero-content p-2 p-lg-0">
                    <h1 class="mb-4">Współpraca</h1>
                    <p class="mb-4">
                        Współpracując z nami, możesz liczyć na prowadzenie pojazdów zgodnie z Twoimi preferencjami, kompleksową organizację transportu oraz precyzyjną wycenę usług. Dbamy o dostosowanie trasy, monitorowanie realizacji i pełną przejrzystość kosztów, aby zapewnić efektywny i zgodny z harmonogramem przewóz.
                    </p>
                    <div class="d-flex align-items-center mb-4 flex-lg-row flex-column text-center text-lg-start">
                        <a href="{{ path('home') }}#contact" class="btn btn-secondary mb-3 mb-lg-0">Skontaktuj się z nami</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Services Section -->
    <section class="services-section py-5">
        <div class="container">
            <div class="row align-items-center mb-5">
                <div class="col-lg-6 order-lg-1 order-2 p-4 px-5">
                    <h2 class="mb-3 fw-bold">
                        <span class="text-danger">Zatrudnimy</span> przewoźników<br>
                        do współpracy!
                    </h2>
                    <p class="text-muted mb-4">
                        Współpraca z wiarygodnymi i profesjonalnymi
                        przewoźnikami jest jednym z kluczowych elementów
                        sukcesu i zadowolenia naszych klientów. Partnerów
                        dobieramy według ustalonych standardów, które
                        gwarantują wysoką jakość obsługi naszych klientów.
                    </p>
                    <a href="{{ path('home') }}#contact" class="btn btn-primary">Rozpocznij współpracę</a>
                </div>
                <div class="col-lg-6 order-lg-2 order-1 mb-4 mb-lg-0">
                    <div class="rounded overflow-hidden">
                        <img src="{{ asset('images/truck.png') }}" alt="Truck cabin interior" class="img-fluid w-100">
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
