{% extends 'base.html.twig' %}

{% block title %}Akwarium - Współpraca{% endblock %}

{% block body %}
    <header class="hero-section mb-12 flex items-center" id="hero" style="background-image: url('{{ asset("images/header-5.jpg") }}') !important;">
        <div class="mx-auto w-full max-w-[1320px] px-3">
            <div class="grid items-center text-center lg:grid-cols-2 lg:text-left">
                <div class="hero-content w-full px-2 lg:px-0">
                    <h1 class="mb-4">Współpraca</h1>
                    <p class="mb-4 max-w-[38rem] text-white/90">
                        Współpracując z nami, możesz liczyć na prowadzenie pojazdów zgodnie z Twoimi preferencjami, kompleksową organizację transportu oraz precyzyjną wycenę usług. Dbamy o dostosowanie trasy, monitorowanie realizacji i pełną przejrzystość kosztów, aby zapewnić efektywny i zgodny z harmonogramem przewóz.
                    </p>
                    <div class="flex justify-center lg:justify-start">
                        <a href="{{ path('home') }}#contact" class="inline-flex min-h-[53px] items-center justify-center rounded-full bg-brand-blue px-5 py-[15px] text-[0.937rem] font-medium text-white no-underline shadow-brand transition duration-200 hover:bg-brand-blue-dark hover:shadow-brand-hover">
                            Skontaktuj się z nami
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <section class="py-12">
        <div class="mx-auto w-full max-w-[1320px] px-3">
            <div class="grid items-center gap-8 lg:grid-cols-2">
                <div class="order-2 px-4 lg:order-1 lg:px-10">
                    <h2 class="mb-3 font-bold">
                        <span class="text-brand-red">Zatrudnimy</span> przewoźników<br>
                        do współpracy!
                    </h2>
                    <p class="mb-4 text-brand-muted">
                        Współpraca z wiarygodnymi i profesjonalnymi
                        przewoźnikami jest jednym z kluczowych elementów
                        sukcesu i zadowolenia naszych klientów. Partnerów
                        dobieramy według ustalonych standardów, które
                        gwarantują wysoką jakość obsługi naszych klientów.
                    </p>
                    <a href="{{ path('home') }}#contact" class="inline-flex min-h-[53px] items-center justify-center rounded-full bg-brand-red px-5 py-[15px] text-[0.937rem] font-medium text-white no-underline shadow-brand transition duration-200 hover:bg-brand-red-dark hover:shadow-brand-hover">
                        Rozpocznij współpracę
                    </a>
                </div>
                <div class="order-1 lg:order-2">
                    <div class="overflow-hidden rounded-[20px]">
                        <img src="{{ asset('images/truck.png') }}" alt="Truck cabin interior" class="w-full">
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
