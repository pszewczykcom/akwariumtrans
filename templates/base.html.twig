                    <ul class="list-none p-0">
                        <li class="mb-4">
                            <a href="{{ path('home') }}" class="no-underline text-white font-light">Strona główna</a>
                        </li>
                        <li class="mb-4">
                            <a href="{{ path('wspolpraca') }}" class="no-underline text-white font-light">Współpraca</a>
                        </li>
                        <li class="mb-4">
                            <a href="{{ path('transport') }}" class="no-underline text-white font-light">Transport</a>
                        </li>
                        <li class="mb-4">
                            <a href="{{ path('logistyka') }}" class="no-underline text-white font-light">Logistyka</a>
                        </li>
                        <li class="mb-4">
                            <a href="{{ path('spedycja') }}" class="no-underline text-white font-light">Spedycja</a>
                        </li>
                    </ul>
                </div>

