<body class="bg-white font-sans text-base font-light text-brand-dark antialiased">
    {% set currentRoute = app.request.attributes.get('_route') %}

    <nav class="site-navbar sticky top-0 z-50 bg-white" data-mobile-nav>
        <div class="mx-auto flex w-full max-w-[1320px] flex-wrap items-center justify-between gap-4 px-3 py-3 lg:flex-nowrap">
            <a class="shrink-0" href="{{ path('home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="Logo" class="h-auto w-20">
            </a>

            <div class="hidden items-center gap-2 sm:flex lg:mr-auto lg:ml-4">
                <span class="inline-flex items-center justify-center text-center">
                    <img src="{{ asset('images/24.png') }}" alt="24/7" class="i24">
                </span>
                <span class="inline-flex items-center justify-center text-center">
                    <img src="{{ asset('images/phone.png') }}" alt="Telefon" class="phone">
                </span>
                <a href="tel:+48604324770" class="phone-link">+48 604 324 770</a>
            </div>

            <button
                class="inline-flex items-center justify-center rounded-md border border-slate-200 p-2 text-brand-dark transition hover:bg-slate-100 lg:hidden"
                type="button"
                aria-controls="navbarSupportedContent"
                aria-expanded="false"
                aria-label="Toggle navigation"
                data-mobile-nav-toggle
            >
                <svg data-mobile-nav-open-icon class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
                </svg>
                <svg data-mobile-nav-close-icon class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
                </svg>
            </button>

            <div
                class="hidden w-full flex-col border-t border-slate-200 pt-4 lg:flex lg:w-auto lg:flex-row lg:items-center lg:border-0 lg:pt-0"
                id="navbarSupportedContent"
                data-mobile-nav-menu
            >
                <ul class="flex w-full flex-col items-center gap-4 text-center lg:ml-auto lg:w-auto lg:flex-row lg:gap-6 lg:text-right">
                    <li>
                        <a class="site-nav-link{{ currentRoute == 'spedycja' ? ' site-nav-link-active' : '' }}" href="{{ path('spedycja') }}">Spedycja</a>
                    </li>
                    <li>
                        <a class="site-nav-link{{ currentRoute == 'transport' ? ' site-nav-link-active' : '' }}" href="{{ path('transport') }}">Transport</a>
                    </li>
                    <li>
                        <a class="site-nav-link{{ currentRoute == 'logistyka' ? ' site-nav-link-active' : '' }}" href="{{ path('logistyka') }}">Logistyka</a>
                    </li>
                    <li>
                        <a class="site-nav-link{{ currentRoute == 'wspolpraca' ? ' site-nav-link-active' : '' }}" href="{{ path('wspolpraca') }}">Współpraca</a>
                    </li>
                    <li class="sm:hidden">
                        <div class="p-2 text-center">
                            <span class="mr-2 inline-flex items-center justify-center">
                                <img src="{{ asset('images/24.png') }}" alt="24/7" class="i24">
                            </span>
                            <span class="mr-2 inline-flex items-center justify-center">
                                <img src="{{ asset('images/phone.png') }}" alt="Telefon" class="phone">
                            </span>
                            <a href="tel:+48604324770" class="phone-link">+48 604 324 770</a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

