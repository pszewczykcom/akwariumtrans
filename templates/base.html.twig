<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <meta property="og:url" content="https://akwariumtrans.pl" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Akwarium - Transport" />
    <meta property="og:description" content="Firma spedycyjno-transportowa – niezawodny partner logistyczny, który dostarczy Twój towar szybko i bezpiecznie w dowolne miejsce na świecie." />
    <meta property="og:image" content="https://akwariumtrans.pl/images/lptp.jpg" />
    <meta property="og:image:secure_url" content="https://akwariumtrans.pl/images/lptp.jpg" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Akwarium - Transport" />
    <meta name="twitter:description" content="Firma spedycyjno-transportowa – niezawodny partner logistyczny, który dostarczy Twój towar szybko i bezpiecznie w dowolne miejsce na świecie." />
    <meta name="twitter:url" content="https://akwariumtrans.pl" />
    <meta name="twitter:image" content="https://akwariumtrans.pl/images/lptp.jpg" />

    <link rel="shortcut icon" href="{{ asset('favicon.ico') }}" sizes="48x48">
    <link rel="icon" type="image/png" href="{{ asset('favicon-16x16.png') }}" sizes="16x16">
    <link rel="icon" type="image/png" href="{{ asset('favicon-32x32.png') }}" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}" sizes="180x180">
    <link rel="manifest" href="{{ asset('site.webmanifest') }}">
    <meta name="apple-mobile-web-app-title" content="Akwarium - Transport" />

    <title>{% block title %}Akwarium - Transport{% endblock %}</title>
    <meta name="description" content="{% block description %}Firma spedycyjno-transportowa – niezawodny partner logistyczny, który dostarczy Twój towar szybko i bezpiecznie w dowolne miejsce na świecie.{% endblock %}"/>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
    tailwind.config = {
        theme: {
            screens: {
                'sm': '576px',
                'md': '768px',
                'lg': '992px',
                'xl': '1200px',
                '2xl': '1400px',
            },
            container: {
                center: true,
                padding: '0.75rem',
                screens: {
                    'sm': '540px',
                    'md': '720px',
                    'lg': '960px',
                    'xl': '1140px',
                    '2xl': '1320px',
                },
            },
            extend: {
                colors: {
                    'brand-red': '#DE2C2C',
                    'brand-red-hover': '#C72525',
                    'brand-dark': '#232427',
                    'brand-cyan': '#2CAFDE',
                    'brand-cyan-hover': '#1c9ecb',
                    'brand-info': '#0dcaf0',
                },
            },
        },
    }
    </script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DSN556B3ET"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DSN556B3ET');
    </script>

    {{ importmap('app') }}
</head>
<body>
    {% set currentRoute = app.request.attributes.get('_route') %}

    <nav class="sticky top-0 bg-white z-50 min-h-[85px] rounded-b-[10px]" data-controller="navbar">
        <div class="container flex flex-wrap items-center min-h-[85px]">
            <a href="{{ path('home') }}" class="shrink-0">
                <img src="{{ asset('images/logo.png') }}" alt="Logo" class="w-20 h-auto">
            </a>

            <div class="hidden sm:flex items-center mr-auto ml-6">
                <span class="inline-block text-center mr-2">
                    <img src="{{ asset('images/24.png') }}" alt="24/7" class="max-w-full h-auto w-[39px]">
                </span>
                <span class="inline-block text-center mr-2">
                    <img src="{{ asset('images/phone.png') }}" alt="Telefon" class="max-w-full h-auto w-[35px]">
                </span>
                <a href="tel:+48604324770" class="no-underline font-medium text-[0.9375rem] text-brand-dark">+48 604 324 770</a>
            </div>

            <button class="lg:hidden p-2 ml-auto" type="button" data-action="navbar#toggle" aria-label="Otwórz menu">
                <svg data-navbar-target="openIcon" class="w-7 h-7 text-brand-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
                <svg data-navbar-target="closeIcon" class="w-7 h-7 text-brand-dark hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

            <div class="hidden lg:flex items-center w-full lg:w-auto" data-navbar-target="menu">
                <ul class="flex flex-col lg:flex-row ml-auto gap-0 sm:gap-6 text-center lg:text-right py-6 lg:py-0 w-full lg:w-auto">
                    <li>
                        <a class="block py-2 lg:py-0 uppercase font-semibold text-[0.9375rem] text-brand-dark hover:underline hover:decoration-red-600 hover:underline-offset-[6px] hover:decoration-2{{ currentRoute == 'spedycja' ? ' underline decoration-red-600 underline-offset-[6px] decoration-2' : '' }}" href="{{ path('spedycja') }}">Spedycja</a>
                    </li>
                    <li>
                        <a class="block py-2 lg:py-0 uppercase font-semibold text-[0.9375rem] text-brand-dark hover:underline hover:decoration-red-600 hover:underline-offset-[6px] hover:decoration-2{{ currentRoute == 'transport' ? ' underline decoration-red-600 underline-offset-[6px] decoration-2' : '' }}" href="{{ path('transport') }}">Transport</a>
                    </li>
                    <li>
                        <a class="block py-2 lg:py-0 uppercase font-semibold text-[0.9375rem] text-brand-dark hover:underline hover:decoration-red-600 hover:underline-offset-[6px] hover:decoration-2{{ currentRoute == 'logistyka' ? ' underline decoration-red-600 underline-offset-[6px] decoration-2' : '' }}" href="{{ path('logistyka') }}">Logistyka</a>
                    </li>
                    <li>
                        <a class="block py-2 lg:py-0 uppercase font-semibold text-[0.9375rem] text-brand-dark hover:underline hover:decoration-red-600 hover:underline-offset-[6px] hover:decoration-2{{ currentRoute == 'wspolpraca' ? ' underline decoration-red-600 underline-offset-[6px] decoration-2' : '' }}" href="{{ path('wspolpraca') }}">Współpraca</a>
                    </li>
                    <li class="sm:hidden">
                        <div class="text-center p-2">
                            <span class="inline-block mr-2">
                                <img src="{{ asset('images/24.png') }}" alt="24/7" class="max-w-full h-auto w-[39px]">
                            </span>
                            <span class="inline-block mr-2">
                                <img src="{{ asset('images/phone.png') }}" alt="Telefon" class="max-w-full h-auto w-[35px]">
                            </span>
                            <a href="tel:+48604324770" class="no-underline font-medium text-[0.9375rem] text-brand-dark">+48 604 324 770</a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

