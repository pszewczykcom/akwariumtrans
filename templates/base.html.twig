                <div class="text-center lg:text-left">
                    <img src="{{ asset('images/logo-footer.png') }}" alt="Akwarium Logo" class="mx-auto mb-4 h-auto w-full max-w-[180px] lg:mx-0">
                    <img src="{{ asset('images/24-white.png') }}" alt="24/7" class="mx-auto h-auto w-full max-w-[35px] lg:mx-0">
                </div>
            </div>

            <div class="text-center lg:text-left">
