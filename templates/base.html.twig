                        <img src="{{ asset('images/logo-footer.png') }}" alt="Akwarium Logo" class="max-w-full h-auto mb-6 block mx-auto" style="max-width: 180px;">
                        <img src="{{ asset('images/24-white.png') }}" alt="24/7" class="max-w-full h-auto block mx-auto" style="max-width: 35px;">
                    </div>
                </div>

                <div class="w-full lg:w-4/12 xl:w-3/12 mb-12 lg:mb-0 text-center lg:text-left">
