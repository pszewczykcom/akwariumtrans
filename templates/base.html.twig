                        <li class="mb-6 flex items-center flex-col lg:flex-row justify-center lg:justify-start">
                            <div class="bg-white rounded flex items-center justify-center mb-2 lg:mb-0 lg:mr-4 w-10 h-10 shrink-0">
                                <svg width="17" height="16" viewBox="0 0 17 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M6.43988 1.42783L7.06739 2.55223C7.63368 3.56693 7.40635 4.89805 6.51445 5.78996C6.51444 5.78996 6.51445 5.78996 6.51444 5.78996C6.51433 5.79008 5.43269 6.87193 7.3941 8.83334C9.35485 10.7941 10.4367 9.71381 10.4375 9.713C10.4375 9.71298 10.4375 9.71299 10.4375 9.71297C11.3294 8.82109 12.6605 8.59377 13.6752 9.16006L14.7996 9.78756C16.3318 10.6427 16.5128 12.7914 15.166 14.1382C14.3567 14.9475 13.3653 15.5772 12.2694 15.6188C10.4245 15.6887 7.29139 15.2218 4.14852 12.0789C1.00566 8.93606 0.53875 5.80294 0.608691 3.95803C0.650237 2.8621 1.27994 1.87072 2.0892 1.06145C3.436 -0.285344 5.58477 -0.10439 6.43988 1.42783Z" fill="#232427"/>
                                </svg>
                            </div>
                            <a href="tel:604324770" class="no-underline text-white font-light">+48 604 324 770</a>
                        </li>
                        <li class="flex flex-col lg:flex-row items-center lg:items-start justify-center lg:justify-start">
                            <div class="bg-white rounded flex items-center justify-center mb-2 lg:mb-0 lg:mr-4 w-10 h-10 shrink-0">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M7.88958 15.8218C12.1613 15.8218 15.6243 14.2634 15.6243 12.3412C15.6243 11.3614 14.7248 10.4763 13.2771 9.84375C12.3938 11.4648 11.0467 12.8621 9.33559 13.5933C8.41587 13.9864 7.36329 13.9864 6.44356 13.5933C4.73249 12.8621 3.3854 11.4648 2.50203 9.84375C1.05439 10.4763 0.154877 11.3614 0.154877 12.3412C0.154877 14.2634 3.61782 15.8218 7.88958 15.8218Z" fill="#232427"/>
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M2.47528 5.39141C2.47528 2.60852 4.89934 0.352539 7.88957 0.352539C10.8798 0.352539 13.3039 2.60852 13.3039 5.39141C13.3039 8.1525 11.5758 11.3744 8.87966 12.5266C8.25115 12.7952 7.52799 12.7952 6.89948 12.5266C4.20334 11.3744 2.47528 8.1525 2.47528 5.39141ZM7.88957 7.31377C8.74392 7.31377 9.43651 6.62118 9.43651 5.76683C9.43651 4.91248 8.74392 4.21989 7.88957 4.21989C7.03522 4.21989 6.34263 4.91248 6.34263 5.76683C6.34263 6.62118 7.03522 7.31377 7.88957 7.31377Z" fill="#232427"/>
