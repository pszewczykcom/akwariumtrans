                    </li>
                    <li>
                        <a href="{{ path('logistyka') }}" class="font-light text-white no-underline transition hover:underline">Logistyka</a>
                    </li>
                    <li>
                        <a href="{{ path('spedycja') }}" class="font-light text-white no-underline transition hover:underline">Spedycja</a>
                    </li>
                </ul>
